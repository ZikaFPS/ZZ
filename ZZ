local UI = {_tabs={}, Toast=Toast, ApplyTheme=ApplyBuiltinTheme, Theme=Theme}

function UI:AddTab(name)
    local idx=#self._tabs+1
    local btn=New("TextButton",{
        Size=UDim2.new(0,0,1,0), AutomaticSize=Enum.AutomaticSize.X,
        BackgroundColor3=idx==1 and Theme.Main or Theme.BG,
        BorderSizePixel=0, Text=name, Font=FONT, TextSize=FONTSIZE,
        TextColor3=Theme.Font, ZIndex=3, LayoutOrder=idx, AutoButtonColor=false,
    }, TabRow)
    Pad(btn,10,0)
    local btnS=Stroke(btn, idx==1 and Theme.Outline or Theme.OutlineDim, 1)
    Reg("Font",btn,"TextColor3")

    local page=New("Frame",{Size=UDim2.new(1,0,0,0),BackgroundTransparency=1,Visible=idx==1,BorderSizePixel=0,ClipsDescendants=false},ContentArea)
    AutoY(page)
    local pi=New("Frame",{Size=UDim2.new(1,-10,0,0),Position=UDim2.new(0,5,0,5),BackgroundTransparency=1,ClipsDescendants=false},page)
    AutoY(pi)
    if IsMobile then VList(pi,8) else HList(pi,4) end

    local cL=New("Frame",{Size=IsMobile and UDim2.new(1,0,0,0) or UDim2.new(0.5,-2,0,0),BackgroundTransparency=1,ClipsDescendants=false,LayoutOrder=1},pi)
    AutoY(cL); VList(cL,8)
    local cR=New("Frame",{Size=IsMobile and UDim2.new(1,0,0,0) or UDim2.new(0.5,-2,0,0),BackgroundTransparency=1,ClipsDescendants=false,LayoutOrder=2},pi)
    AutoY(cR); VList(cR,8)

    local tab={_colLeft=cL, _colRight=cR, _panelCount=0}
    self._tabs[idx]={page=page, btn=btn, stroke=btnS}

    local function activate()
        for i,t in ipairs(self._tabs) do
            t.page.Visible=(i==idx)
            t.btn.BackgroundColor3=(i==idx) and Theme.Main or Theme.BG
            t.stroke.Color=(i==idx) and Theme.Outline or Theme.OutlineDim
        end
    end
    btn.MouseButton1Click:Connect(activate)
    btn.TouchTap:Connect(activate)

    function tab:AddPanel(n, side)
        self._panelCount=self._panelCount+1
        local col = side=="right" and self._colRight
                 or side=="left"  and self._colLeft
                 or (self._panelCount%2==1 and self._colLeft or self._colRight)
        return BuildPanel(col, n, self._panelCount)
    end

    return tab
end

