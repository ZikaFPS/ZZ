MiniRestoreBtn.MouseButton1Click:Connect(doRestore)
CloseBtn.MouseButton1Click:Connect(destroyUI)
MiniCloseBtn.MouseButton1Click:Connect(destroyUI)

-- Keyboard hotkey (PC) — hides WITHOUT mini bar
UserInputService.InputBegan:Connect(function(inp, gpe)
    if gpe then return end
    if inp.UserInputType ~= Enum.UserInputType.Keyboard then return end
    if inp.KeyCode == ZikaFPS.MinimizeKey then
        if ZikaFPS.IsMinimized then
            ZikaFPS.IsMinimized = false
            MiniBar.Visible     = false
            MainFrame.Visible   = true
        else
            ZikaFPS.IsMinimized = true
            MainFrame.Visible   = false
            MiniBar.Visible     = false
        end
    end
end)

