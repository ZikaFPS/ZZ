    ["Purple"]    = {BG=Color3.fromRGB(14,8,22),   Main=Color3.fromRGB(18,10,30),  Accent=Color3.fromRGB(160,0,255),  Outline=Color3.fromRGB(90,0,160),   Font=Color3.fromRGB(230,200,255)},
}

-- Registry para re-colorir ao trocar tema
local Registry = {}
local ColorPrevs = {}

local function Reg(key, inst, prop)
    if not Registry[key] then Registry[key] = {} end
    table.insert(Registry[key], {inst=inst, prop=prop or "BackgroundColor3"})
end

local function ApplyTheme()
    for key, list in pairs(Registry) do
        local color = Theme[key]
        if color then
            for _, e in ipairs(list) do
                pcall(function() e.inst[e.prop] = color end)
            end
        end
    end
    for key, prev in pairs(ColorPrevs) do
        if Theme[key] then pcall(function() prev.BackgroundColor3 = Theme[key] end) end
    end
end

local function ApplyBuiltinTheme(name)
    local t = BuiltinThemes[name]
    if not t then return end
    for k, c in pairs(t) do Theme[k] = c end
    Theme.AccentOff  = Theme.BG
    Theme.Input      = Color3.fromRGB(14,14,14)
    Theme.OutlineDim = Color3.fromRGB(55,55,55)
    Theme.Hover      = Color3.fromRGB(Theme.Main.R*255+8, Theme.Main.G*255+8, Theme.Main.B*255+8)
    ApplyTheme()
end

-- ============================================================
-- HELPERS
-- ============================================================
local FONT     = Enum.Font.Code
local FONTSIZE = IsMobile and 14 or 13

local function New(class, props, parent)
    local i = Instance.new(class)
    for k,v in pairs(props) do i[k]=v end
    if parent then i.Parent=parent end
    return i
end

local function Stroke(inst, color, thick)
    local s = Instance.new("UIStroke")
    s.Color=color or Theme.Outline; s.Thickness=thick or 1
    s.LineJoinMode=Enum.LineJoinMode.Miter; s.Parent=inst; return s
end

local function Pad(inst, x, y)
    local p = Instance.new("UIPadding")
    p.PaddingLeft=UDim.new(0,x or 6); p.PaddingRight=UDim.new(0,x or 6)
    p.PaddingTop=UDim.new(0,y or 4); p.PaddingBottom=UDim.new(0,y or 4)
    p.Parent=inst
end

local function VList(inst, gap)
    local l=Instance.new("UIListLayout")
    l.FillDirection=Enum.FillDirection.Vertical
    l.SortOrder=Enum.SortOrder.LayoutOrder
    l.Padding=UDim.new(0,gap or 3); l.Parent=inst; return l
end

local function HList(inst, gap)
    local l=Instance.new("UIListLayout")
    l.FillDirection=Enum.FillDirection.Horizontal
    l.SortOrder=Enum.SortOrder.LayoutOrder
    l.VerticalAlignment=Enum.VerticalAlignment.Center
    l.Padding=UDim.new(0,gap or 5); l.Parent=inst; return l
end

local function AutoY(inst) inst.AutomaticSize = Enum.AutomaticSize.Y end

local function Connect(inst, event, cb)
    inst[event]:Connect(cb)
    if event == "MouseButton1Click" then
        inst.TouchTap:Connect(cb)
    end
end

