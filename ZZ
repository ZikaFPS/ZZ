local function BuildPanel(parentCol, name, order)
    local wrapper=New("Frame",{Size=UDim2.new(1,0,0,0),BackgroundTransparency=1,BorderSizePixel=0,ClipsDescendants=false,LayoutOrder=order},parentCol)
    AutoY(wrapper); VList(wrapper,0)
    New("Frame",{Size=UDim2.new(1,0,0,9),BackgroundTransparency=1,LayoutOrder=1},wrapper)

    local container=New("Frame",{Size=UDim2.new(1,0,0,0),BackgroundColor3=Theme.Main,BorderSizePixel=0,ClipsDescendants=false,LayoutOrder=2},wrapper)
    AutoY(container)
    local cS=Stroke(container,Theme.Outline,1)
    Reg("Main",container); Reg("Outline",cS,"Color")

    if name and name~="" then
        local tl=New("TextLabel",{
            Size=UDim2.new(0,#name*7+12,0,14), Position=UDim2.new(0,8,0,-7),
            BackgroundColor3=Theme.Main, BorderSizePixel=0,
            Text=name, Font=FONT, TextSize=FONTSIZE-1, TextColor3=Theme.Font, ZIndex=5,
        }, container)
        local tlS=Stroke(tl,Theme.Outline,1)
        Reg("Main",tl); Reg("Outline",tlS,"Color"); Reg("Font",tl,"TextColor3")
    end

    local inner=New("Frame",{
        Size=UDim2.new(1,-8,0,0), Position=UDim2.new(0,4,0,10),
        BackgroundTransparency=1, BorderSizePixel=0, ClipsDescendants=false, ZIndex=2,
    }, container)
    AutoY(inner); VList(inner,3)
    New("Frame",{Size=UDim2.new(1,0,0,4),BackgroundTransparency=1,LayoutOrder=0},inner)

    local panel = {_inner=inner, _order=0}
    local function N() panel._order=panel._order+1; return panel._order end

    -- ========== Toggle ==========
    function panel:AddToggle(label, default, callback)
        local state = default or false
        local row=New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,LayoutOrder=N()},inner)
        HList(row,5)
        local box=New("Frame",{Size=UDim2.new(0,12,0,12),BackgroundColor3=state and Theme.Accent or Theme.AccentOff,BorderSizePixel=0},row)
        local bS=Stroke(box, state and Theme.Outline or Theme.OutlineDim, 1)
        local lbl=New("TextLabel",{Size=UDim2.new(1,-22,0,18),BackgroundTransparency=1,Text=label,Font=FONT,TextSize=FONTSIZE,TextColor3=Theme.Font,TextXAlignment=Enum.TextXAlignment.Left},row)
        Reg("Font",lbl,"TextColor3")
        local clk=New("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=4},row)
        local function toggle()
            state=not state
            box.BackgroundColor3=state and Theme.Accent or Theme.AccentOff
            bS.Color=state and Theme.Outline or Theme.OutlineDim
            if callback then pcall(callback, state) end
        end
        clk.MouseButton1Click:Connect(toggle)
        clk.TouchTap:Connect(toggle)
        local obj = {GetValue=function() return state end, SetValue=function(_,v) state=v; box.BackgroundColor3=v and Theme.Accent or Theme.AccentOff; bS.Color=v and Theme.Outline or Theme.OutlineDim end}
        return obj
    end

    -- ========== Checkbox ==========
    function panel:AddCheckbox(label, default, callback)
        local state = default or false
        local row=New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,LayoutOrder=N()},inner)
        HList(row,5)
        local box=New("Frame",{Size=UDim2.new(0,12,0,12),BackgroundColor3=state and Theme.Accent or Theme.BG3,BorderSizePixel=0},row)
        local bS=Stroke(box,Theme.OutlineDim,1); Reg("OutlineDim",bS,"Color")
        local chk=New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=state and "✓" or "",Font=FONT,TextSize=10,TextColor3=Theme.White,TextXAlignment=Enum.TextXAlignment.Center},box)
        local lbl=New("TextLabel",{Size=UDim2.new(1,-22,0,18),BackgroundTransparency=1,Text=label,Font=FONT,TextSize=FONTSIZE,TextColor3=Theme.Font,TextXAlignment=Enum.TextXAlignment.Left},row)
        Reg("Font",lbl,"TextColor3")
        local clk=New("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=4},row)
        local function toggle()
            state=not state
            box.BackgroundColor3=state and Theme.Accent or Theme.BG3
            bS.Color=state and Theme.Outline or Theme.OutlineDim
            chk.Text=state and "✓" or ""
            if callback then pcall(callback, state) end
        end
        clk.MouseButton1Click:Connect(toggle); clk.TouchTap:Connect(toggle)
        return {GetValue=function() return state end, SetValue=function(_,v) state=v; box.BackgroundColor3=v and Theme.Accent or Theme.BG3; chk.Text=v and "✓" or "" end}
    end

    -- ========== Slider ==========
    function panel:AddSlider(label, min, max, default, callback)
        min=min or 0; max=max or 100; default=default or min
        local value=default
        local col=New("Frame",{Size=UDim2.new(1,0,0,30),BackgroundTransparency=1,LayoutOrder=N()},inner)
        VList(col,2)
        local lbl2=New("TextLabel",{Size=UDim2.new(1,0,0,14),BackgroundTransparency=1,Text=label,Font=FONT,TextSize=FONTSIZE,TextColor3=Theme.Font,TextXAlignment=Enum.TextXAlignment.Left},col)
        Reg("Font",lbl2,"TextColor3")
        local track=New("Frame",{Size=UDim2.new(1,0,0,14),BackgroundColor3=Theme.BG3,BorderSizePixel=0},col)
        local tS=Stroke(track,Theme.OutlineDim,1); Reg("BG3",track); Reg("OutlineDim",tS,"Color")
        local pct=(value-min)/(max-min)
        local fill=New("Frame",{Size=UDim2.new(pct,0,1,0),BackgroundColor3=Theme.Accent,BorderSizePixel=0,ZIndex=2},track)
        Reg("Accent",fill)
        local vLbl=New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=tostring(value).."/"..tostring(max),Font=FONT,TextSize=11,TextColor3=Theme.White,ZIndex=3},track)
        local function update(absX)
            local r=math.clamp((absX-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
            value=math.floor(min+r*(max-min)); fill.Size=UDim2.new(r,0,1,0)
            vLbl.Text=tostring(value).."/"..tostring(max)
            if callback then pcall(callback, value) end
        end
        local sl=false
        track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sl=true; update(i.Position.X) end end)
        track.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sl=false end end)
        UserInputService.InputChanged:Connect(function(i)
            if sl and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then update(i.Position.X) end
        end)
        return {
            GetValue=function() return value end,
            SetValue=function(_,v)
                value=v; local r=(v-min)/(max-min)
                fill.Size=UDim2.new(r,0,1,0); vLbl.Text=tostring(v).."/"..tostring(max)
            end
        }
    end

    -- ========== Dropdown ==========
    function panel:AddDropdown(label, options, callback)
        local selected=options[1]
        local col=New("Frame",{Size=UDim2.new(1,0,0,0),BackgroundTransparency=1,LayoutOrder=N(),ClipsDescendants=false},inner)
        AutoY(col); VList(col,2)
        if label and label~="" then
            local dl=New("TextLabel",{Size=UDim2.new(1,0,0,14),BackgroundTransparency=1,Text=label,Font=FONT,TextSize=FONTSIZE,TextColor3=Theme.Font,TextXAlignment=Enum.TextXAlignment.Left},col)
            Reg("Font",dl,"TextColor3")
        end
        local btnF=New("Frame",{Size=UDim2.new(1,0,0,22),BackgroundColor3=Theme.Input,BorderSizePixel=0,ClipsDescendants=false,ZIndex=10},col)
        local bFS=Stroke(btnF,Theme.OutlineDim,1); Reg("Input",btnF); Reg("OutlineDim",bFS,"Color")
        local sLbl=New("TextLabel",{Size=UDim2.new(1,-20,1,0),Position=UDim2.new(0,6,0,0),BackgroundTransparency=1,Text=selected,Font=FONT,TextSize=FONTSIZE,TextColor3=Theme.Font,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=11},btnF)
        Reg("Font",sLbl,"TextColor3")
        New("TextLabel",{Size=UDim2.new(0,16,1,0),Position=UDim2.new(1,-18,0,0),BackgroundTransparency=1,Text="▼",Font=FONT,TextSize=10,TextColor3=Theme.FontDim,ZIndex=11},btnF)
        local dList=New("ScrollingFrame",{Size=UDim2.new(1,0,0,math.min(#options,5)*22),Position=UDim2.new(0,0,1,1),BackgroundColor3=Theme.Main,BorderSizePixel=0,Visible=false,ZIndex=20,ScrollBarThickness=4,ScrollBarImageColor3=Theme.Accent,CanvasSize=UDim2.new(0,0,0,#options*22)},btnF)
        Stroke(dList,Theme.Outline,1); VList(dList,0); Reg("Main",dList); Reg("Accent",dList,"ScrollBarImageColor3")
        for _,opt in ipairs(options) do
            local item=New("TextButton",{Size=UDim2.new(1,0,0,22),BackgroundColor3=Theme.Main,BorderSizePixel=0,Text=opt,Font=FONT,TextSize=FONTSIZE,TextColor3=Theme.Font,ZIndex=21,AutoButtonColor=false},dList)
            Reg("Main",item); Reg("Font",item,"TextColor3")
            item.MouseEnter:Connect(function() item.BackgroundColor3=Theme.Hover end)
            item.MouseLeave:Connect(function() item.BackgroundColor3=Theme.Main end)
            local function sel() selected=opt; sLbl.Text=opt; dList.Visible=false; if callback then pcall(callback,opt) end end
            item.MouseButton1Click:Connect(sel); item.TouchTap:Connect(sel)
        end
        local open=false
        local clk=New("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=12},btnF)
        local function toggleOpen() open=not open; dList.Visible=open end
        clk.MouseButton1Click:Connect(toggleOpen); clk.TouchTap:Connect(toggleOpen)
        return {
            GetValue=function() return selected end,
            SetValue=function(_,v) selected=v; sLbl.Text=v end,
            SetOptions=function(_,opts)
                dList:ClearAllChildren(); VList(dList,0)
                dList.CanvasSize=UDim2.new(0,0,0,#opts*22)
                dList.Size=UDim2.new(1,0,0,math.min(#opts,5)*22)
                for _,opt in ipairs(opts) do
                    local item2=New("TextButton",{Size=UDim2.new(1,0,0,22),BackgroundColor3=Theme.Main,BorderSizePixel=0,Text=opt,Font=FONT,TextSize=FONTSIZE,TextColor3=Theme.Font,ZIndex=21,AutoButtonColor=false},dList)
                    Reg("Main",item2); Reg("Font",item2,"TextColor3")
                    item2.MouseEnter:Connect(function() item2.BackgroundColor3=Theme.Hover end)
                    item2.MouseLeave:Connect(function() item2.BackgroundColor3=Theme.Main end)
                    local function sel2() selected=opt; sLbl.Text=opt; dList.Visible=false; if callback then pcall(callback,opt) end end
                    item2.MouseButton1Click:Connect(sel2); item2.TouchTap:Connect(sel2)
                end
            end
        }
    end

    -- ========== Button ==========
