            local vl2=New("TextLabel",{Size=UDim2.new(0,24,1,0),BackgroundTransparency=1,Text=tostring(math.floor(rgb2[ch2])),Font=FONT,TextSize=10,TextColor3=Theme.Font},sr); Reg("Font",vl2,"TextColor3")
