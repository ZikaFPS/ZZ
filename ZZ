local BuiltinThemes = {
    ["Default"]   = {BG=Color3.fromRGB(22,22,22),  Main=Color3.fromRGB(28,28,28),  Accent=Color3.fromRGB(0,100,220),  Outline=Color3.fromRGB(0,75,180),   Font=Color3.fromRGB(200,200,200)},
    ["Dark Blue"] = {BG=Color3.fromRGB(8,13,26),   Main=Color3.fromRGB(11,18,36),  Accent=Color3.fromRGB(30,144,255), Outline=Color3.fromRGB(20,60,130),  Font=Color3.fromRGB(210,220,255)},
    ["Midnight"]  = {BG=Color3.fromRGB(8,8,8),     Main=Color3.fromRGB(14,14,14),  Accent=Color3.fromRGB(130,0,255),  Outline=Color3.fromRGB(70,0,140),   Font=Color3.fromRGB(220,170,255)},
    ["Red"]       = {BG=Color3.fromRGB(22,8,8),    Main=Color3.fromRGB(28,10,10),  Accent=Color3.fromRGB(210,30,0),   Outline=Color3.fromRGB(110,15,0),   Font=Color3.fromRGB(255,200,200)},
