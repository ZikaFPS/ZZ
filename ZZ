    end); mO=mO+1
    SBtn(mI,"Refresh list",mO+1,function() refreshCT(); Toast("Atualizado!") end); mO=mO+1
    SBtn(mI,"Set as default",mO+1,function() local sel=ctDDVal.Text; if sel=="--" then Toast("Selecione!"); return end; Toast("\""..sel.."\" padrão!") end); mO=mO+1
    SGap(mI,999)

    -- PAINEL CONFIGURATION (direita)
    local cPanel=BuildPanel(sR,"Configuration",1)
    local cI=cPanel._inner; local cO=cPanel._order

    SLbl(cI,"Config name",cO+1); cO=cO+1
