    mkCorner(track, 11)
    local tStroke = mkStroke(track, on and C.ACCENT or C.BORDER)

    local knob = mkFrame({
        Size             = UDim2.new(0, 16, 0, 16),
        Position         = on and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8),
        BackgroundColor3 = C.WHITE,
        ZIndex           = 12,
        Parent           = track,
    })
    mkCorner(knob, 8)

    local hitbox = mkBtn({
        Size             = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        Text             = "",
        ZIndex           = 13,
        Parent           = track,
    })

    local function doToggle()
        on = not on
        tw(track, {BackgroundColor3 = on and C.TOG_ON or C.TOG_OFF})
        tw(knob,  {Position = on and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)})
        tStroke.Color = on and C.ACCENT or C.BORDER
        if callback then callback(on) end
    end

    hitbox.MouseButton1Click:Connect(doToggle)
    hitbox.TouchTap:Connect(doToggle)

    return {
        GetValue = function() return on end,
        SetValue = function(v)
            if on ~= v then doToggle() end
        end,
    }
end

-- ── createKeyBind ────────────────────────────────────
local function createKeyBind(parent, label, defaultKey, callback)
    local currentKey = defaultKey or "None"
    local listening  = false

    local ROW_H = IsMobile and 34 or 26
    local row = mkFrame({
        Size          = UDim2.new(1, 0, 0, ROW_H),
        BackgroundTransparency = 1,
        ZIndex        = 10,
        Parent        = parent,
    })

    mkLabel({
        Size           = UDim2.new(1, -50, 1, 0),
        Text           = label,
        TextSize       = IsMobile and 13 or 12,
        TextColor3     = C.SUBTEXT,
        Font           = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex         = 11,
        Parent         = row,
    })

    local badge = mkBtn({
        Size             = UDim2.new(0, 42, 0, 24),
        Position         = UDim2.new(1, -42, 0.5, -12),
        BackgroundColor3 = Color3.fromRGB(26,30,56),
        Text             = currentKey,
        Font             = Enum.Font.GothamBold,
        TextSize         = 10,
        TextColor3       = C.SUBTEXT,
        ZIndex           = 11,
        Parent           = row,
    })
    mkCorner(badge, 6)
    mkStroke(badge, C.BORDER)

    local conn
    local function startListen()
        if listening then return end
        listening  = true
        badge.Text = "..."
        tw(badge, {TextColor3 = C.ACCENT})
        if conn then conn:Disconnect() end
        conn = UserInputService.InputBegan:Connect(function(inp)
            if inp.UserInputType ~= Enum.UserInputType.Keyboard then return end
            currentKey = inp.KeyCode.Name
            local display = #currentKey > 8 and currentKey:sub(1,8) or currentKey
            badge.Text = display
            tw(badge, {TextColor3 = C.SUBTEXT})
            listening = false
            conn:Disconnect()
            if callback then callback(inp.KeyCode) end
        end)
    end

    badge.MouseButton1Click:Connect(startListen)
    badge.TouchTap:Connect(startListen)

    return {
        GetKey    = function() return currentKey end,
        GetKeyCode= function()
            local ok2, kc = pcall(function() return Enum.KeyCode[currentKey] end)
            return ok2 and kc or nil
        end,
    }
end

-- ── createSlider ─────────────────────────────────────
local function createSlider(parent, label, default, minV, maxV, callback)
    local val = math.clamp(default or minV, minV, maxV)

    local container = mkFrame({
        Size          = UDim2.new(1, 0, 0, IsMobile and 50 or 42),
        BackgroundTransparency = 1,
        ZIndex        = 10,
        Parent        = parent,
    })

    mkLabel({
        Size           = UDim2.new(1, -42, 0, 16),
        Text           = label,
        TextSize       = IsMobile and 12 or 11,
        TextColor3     = C.MUTED,
        Font           = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex         = 11,
        Parent         = container,
    })
    local valLbl = mkLabel({
        Size           = UDim2.new(0, 40, 0, 16),
        Position       = UDim2.new(1, -40, 0, 0),
        Text           = tostring(val),
        TextSize       = IsMobile and 12 or 11,
        TextColor3     = C.SUBTEXT,
        Font           = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
        ZIndex         = 11,
        Parent         = container,
    })

    local TRACK_Y = IsMobile and 28 or 22
    local trackBg = mkFrame({
        Size             = UDim2.new(1, 0, 0, IsMobile and 6 or 4),
        Position         = UDim2.new(0, 0, 0, TRACK_Y),
        BackgroundColor3 = C.BORDER,
        ZIndex           = 11,
        Parent           = container,
    })
    mkCorner(trackBg, 3)

    local pct0 = (val - minV) / (maxV - minV)
    local fill = mkFrame({
        Size             = UDim2.new(pct0, 0, 1, 0),
        BackgroundColor3 = C.ACCENT,
        ZIndex           = 12,
        Parent           = trackBg,
    })
    mkCorner(fill, 3)

    local THUMB = IsMobile and 18 or 14
    local thumb = mkFrame({
        Size             = UDim2.new(0, THUMB, 0, THUMB),
        AnchorPoint      = Vector2.new(0.5, 0.5),
        Position         = UDim2.new(pct0, 0, 0.5, 0),
        BackgroundColor3 = C.ACCENT,
        ZIndex           = 13,
        Parent           = trackBg,
    })
    mkCorner(thumb, THUMB/2)

    -- Larger hit area for touch
    local HIT_H = IsMobile and 30 or 18
    local hitbox = mkBtn({
        Size             = UDim2.new(1, 0, 0, HIT_H),
        Position         = UDim2.new(0, 0, 0.5, -HIT_H/2),
        BackgroundTransparency = 1,
        Text             = "",
        ZIndex           = 14,
        Parent           = trackBg,
    })

    local dragging = false
    local function updateFromPos(x)
        local pos = trackBg.AbsolutePosition.X
        local w   = trackBg.AbsoluteSize.X
        local p   = math.clamp((x - pos) / w, 0, 1)
        val = math.round(minV + (maxV - minV) * p)
        valLbl.Text    = tostring(val)
        fill.Size      = UDim2.new(p, 0, 1, 0)
        thumb.Position = UDim2.new(p, 0, 0.5, 0)
        if callback then callback(val) end
    end

    -- Mouse
    hitbox.MouseButton1Down:Connect(function()
        dragging = true
        updateFromPos(Mouse.X)
    end)
    -- Touch
    hitbox.TouchPan:Connect(function(_, totalTrans, _, state)
        local startX = hitbox.AbsolutePosition.X
        updateFromPos(startX + totalTrans.X)
    end)
    hitbox.TouchTap:Connect(function(touches)
        if touches[1] then updateFromPos(touches[1].Position.X) end
    end)

    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            updateFromPos(Mouse.X)
        end
    end)

    return {
        GetValue = function() return val end,
        SetValue = function(v)
            val = math.clamp(v, minV, maxV)
            local p = (val - minV) / (maxV - minV)
            valLbl.Text    = tostring(val)
            fill.Size      = UDim2.new(p, 0, 1, 0)
            thumb.Position = UDim2.new(p, 0, 0.5, 0)
        end,
    }
end

-- ── createButton ─────────────────────────────────────
local function createButton(parent, label, style, callback)
    -- style: "primary" | "secondary" | "danger"
    local isPrimary = style == "primary"
    local isDanger  = style == "danger"
    local bg  = isPrimary and C.BTN_PRI or (isDanger and C.BTN_DNG or C.BTN_SEC)
    local tc  = isPrimary and C.WHITE   or (isDanger and C.BTN_DNG_T or C.SUBTEXT)
    local hbg = isPrimary and Color3.fromRGB(110,115,255)
                           or (isDanger and Color3.fromRGB(46,18,18) or Color3.fromRGB(34,38,74))

    local btn = mkBtn({
        Size             = UDim2.new(1, 0, 0, IsMobile and 40 or 34),
        BackgroundColor3 = bg,
        Text             = label,
        Font             = Enum.Font.GothamBold,
        TextSize         = IsMobile and 14 or 13,
        TextColor3       = tc,
        ZIndex           = 10,
        Parent           = parent,
    })
    mkCorner(btn, 8)
    if not isPrimary then
        mkStroke(btn, isDanger and Color3.fromRGB(90,32,32) or C.BORDER)
    end

    btn.MouseEnter:Connect(function() tw(btn,{BackgroundColor3=hbg}) end)
    btn.MouseLeave:Connect(function() tw(btn,{BackgroundColor3=bg}) end)
    local function doClick() if callback then callback() end end
    btn.MouseButton1Click:Connect(doClick)
    btn.TouchTap:Connect(doClick)

    return btn
end

-- ── createLabel (display only) ───────────────────────
local function createInfoLabel(parent, text)
    local lbl = mkLabel({
        Size           = UDim2.new(1, 0, 0, IsMobile and 22 or 18),
        Text           = text,
        TextSize       = IsMobile and 13 or 12,
        TextColor3     = C.MUTED,
        Font           = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex         = 10,
        Parent         = parent,
    })
    return lbl
end

