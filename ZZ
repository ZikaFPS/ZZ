-- ── createSectionGrid ────────────────────────────────
-- Returns a frame that lays its children in 2 columns (or 1 on very small mobile)
local function createSectionGrid(parent)
    local cols     = (IsMobile and WIN_W < 360) and 1 or 2
    local cellGap  = 10
    local cellW    = math.floor((WIN_W - SIDEBAR_W - 24 - (cols-1)*cellGap) / cols)

    local grid = mkFrame({
        Size          = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        ZIndex        = 7,
        Parent        = parent,
    })

    local gl = Instance.new("UIGridLayout")
    gl.CellSize          = UDim2.new(0, cellW, 0, 0)
    gl.AutomaticCellSize = Enum.AutomaticCellSize.Y
    gl.CellPadding       = UDim2.new(0, cellGap, 0, cellGap)
    gl.FillDirection     = Enum.FillDirection.Horizontal
    gl.SortOrder         = Enum.SortOrder.LayoutOrder
    gl.Parent            = grid

    return grid
end

