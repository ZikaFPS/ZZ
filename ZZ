-- ── createNavItem ────────────────────────────────────
local function createNavItem(icon, label, tabName)
    local btn = mkBtn({
        Size             = UDim2.new(1, 0, 0, IsMobile and 42 or 36),
        BackgroundColor3 = C.SIDEBAR,
        Text             = "",
        ZIndex           = 7,
        Parent           = Sidebar,
    })
    mkCorner(btn, 8)

    -- mobile: icon only; PC: icon + text
    if IsMobile then
        mkLabel({
            Size           = UDim2.fromScale(1, 1),
            Text           = icon,
            TextSize       = 18,
            TextColor3     = C.MUTED,
            Font           = Enum.Font.GothamBold,
            ZIndex         = 8,
            Parent         = btn,
        })
    else
        mkLabel({
            Size           = UDim2.new(0, 20, 1, 0),
            Position       = UDim2.new(0, 10, 0, 0),
            Text           = icon,
            TextSize       = 14,
            TextColor3     = C.MUTED,
            Font           = Enum.Font.GothamBold,
            ZIndex         = 8,
            Parent         = btn,
        })
        local textL = mkLabel({
            Size           = UDim2.new(1, -38, 1, 0),
            Position       = UDim2.new(0, 34, 0, 0),
            Text           = label,
            TextSize       = 13,
            TextColor3     = C.SUBTEXT,
            Font           = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex         = 8,
            Parent         = btn,
        })
        ZikaFPS.NavItems[tabName] = ZikaFPS.NavItems[tabName] or {}
        ZikaFPS.NavItems[tabName].textLabel = textL
    end

    local function setActive(on)
        tw(btn, {BackgroundColor3 = on and C.NAV_ACT or C.SIDEBAR})
        if ZikaFPS.NavItems[tabName] and ZikaFPS.NavItems[tabName].textLabel then
            tw(ZikaFPS.NavItems[tabName].textLabel, {TextColor3 = on and C.WHITE or C.SUBTEXT})
        end
    end

    btn.MouseEnter:Connect(function()
        if ZikaFPS.ActiveTab ~= tabName then tw(btn,{BackgroundColor3=C.NAV_HOV}) end
    end)
    btn.MouseLeave:Connect(function()
        if ZikaFPS.ActiveTab ~= tabName then tw(btn,{BackgroundColor3=C.SIDEBAR}) end
    end)

    btn.MouseButton1Click:Connect(function()
        if ZikaFPS.ActiveTab and ZikaFPS.TabPanels[ZikaFPS.ActiveTab] then
            ZikaFPS.TabPanels[ZikaFPS.ActiveTab].Visible = false
        end
        for name, item in pairs(ZikaFPS.NavItems) do
            if item.setActive then item.setActive(false) end
        end
        ZikaFPS.ActiveTab = tabName
        setActive(true)
        if ZikaFPS.TabPanels[tabName] then
            ZikaFPS.TabPanels[tabName].Visible = true
        end
    end)

    ZikaFPS.NavItems[tabName] = ZikaFPS.NavItems[tabName] or {}
    ZikaFPS.NavItems[tabName].setActive = setActive
    ZikaFPS.NavItems[tabName].btn       = btn
end

